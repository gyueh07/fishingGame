rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email == 'admin@fishinglife.app';
    }

    function currentWriteSchema() {
      return 250;
    }

    function currentWriteProtocol() {
      return 4;
    }

    function validWriteEnvelope(data) {
      return data.keys().hasAll([
          'writeSchemaVersion',
          'writeProtocol',
          'writeProtocolSeq',
          'writeGuardAt',
          'updatedAt'
        ])
        && data.writeSchemaVersion is int
        && data.writeSchemaVersion == currentWriteSchema()
        && data.writeProtocol is int
        && data.writeProtocol == currentWriteProtocol()
        && data.writeProtocolSeq is int
        && data.writeGuardAt is timestamp
        && data.writeGuardAt == request.time
        && data.updatedAt is timestamp
        && data.updatedAt == request.time;
    }

    function validUserCore(data) {
      let state = data.gameState;
      return data.keys().hasAll([
          'nickname',
          'money',
          'rodLevel',
          'totalEarned',
          'totalFishingCount',
          'accountResetVersion',
          'cloudRevision',
          'gameState'
        ])
        && data.nickname is string
        && data.money is number
        && data.rodLevel is int
        && data.totalEarned is number
        && data.totalFishingCount is int
        && data.accountResetVersion is int
        && data.accountResetVersion == 1
        && data.cloudRevision is int
        && state is map
        && state.keys().hasAll([
          'saveSchemaVersion',
          'money',
          'rodLevel',
          'totalEarned',
          'totalFishingCount',
          'accountResetVersion'
        ])
        && state.saveSchemaVersion is int
        && state.saveSchemaVersion == currentWriteSchema()
        && state.money is number
        && state.rodLevel is int
        && state.totalEarned is number
        && state.totalFishingCount is int
        && state.accountResetVersion is int
        && state.accountResetVersion == 1
        && data.money == state.money
        && data.rodLevel == state.rodLevel
        && data.totalEarned == state.totalEarned
        && data.totalFishingCount == state.totalFishingCount
        && data.money >= 0
        && data.rodLevel >= 1
        && data.totalEarned >= 0
        && data.totalFishingCount >= 0;
    }

    function writeGuardChanged() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasAny(['writeGuardAt'])
        && affected.hasAny(['writeProtocolSeq'])
        && affected.hasAny(['updatedAt']);
    }

    function identityFieldsUnchanged() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return !affected.hasAny(['passwordHash', 'createdAt'])
        && (!affected.hasAny(['nickname'])
          || !resource.data.keys().hasAny(['nickname']));
    }

    function validUpdateSequence() {
      return request.resource.data.cloudRevision
          == resource.data.get('cloudRevision', 0) + 1
        && request.resource.data.writeProtocolSeq
          == resource.data.get('writeProtocolSeq', 0) + 1;
    }

    function progressDoesNotRegress() {
      let oldState = resource.data.get('gameState', {});
      return request.resource.data.rodLevel
          >= resource.data.get('rodLevel', oldState.get('rodLevel', 1))
        && request.resource.data.gameState.rodLevel
          >= oldState.get('rodLevel', resource.data.get('rodLevel', 1))
        && request.resource.data.totalFishingCount
          >= resource.data.get('totalFishingCount', oldState.get('totalFishingCount', 0))
        && request.resource.data.gameState.totalFishingCount
          >= oldState.get('totalFishingCount', resource.data.get('totalFishingCount', 0))
        && request.resource.data.totalEarned
          >= resource.data.get('totalEarned', oldState.get('totalEarned', 0))
        && request.resource.data.gameState.totalEarned
          >= oldState.get('totalEarned', resource.data.get('totalEarned', 0));
    }

    function validFullReset() {
      let state = request.resource.data.gameState;
      return resource.data.get('accountResetVersion', 0) < 1
        && request.resource.data.accountResetVersion == 1
        && request.resource.data.money == 0
        && request.resource.data.rodLevel == 1
        && request.resource.data.totalEarned == 0
        && request.resource.data.totalFishingCount == 0
        && state.money == 0
        && state.rodLevel == 1
        && state.totalEarned == 0
        && state.totalFishingCount == 0
        && state.bucket is list
        && state.bucket.size() == 0;
    }

    function activeSessionMatches(userId) {
      let session = get(/databases/$(database)/documents/accountSessions/$(userId));
      return resource.data.activeSessionTokenHash is string
        && resource.data.activeSessionTokenHash.size() > 0
        && session.data.tokenHash == resource.data.activeSessionTokenHash
        && session.data.deviceId == resource.data.activeSessionDeviceId;
    }

    function parentActiveSessionMatches(userId) {
      let user = get(/databases/$(database)/documents/users/$(userId));
      let session = get(/databases/$(database)/documents/accountSessions/$(userId));
      return user.data.activeSessionTokenHash is string
        && user.data.activeSessionTokenHash.size() > 0
        && session.data.tokenHash == user.data.activeSessionTokenHash
        && session.data.deviceId == user.data.activeSessionDeviceId;
    }

    function parentRevisionAdvanced(userId) {
      let before = get(/databases/$(database)/documents/users/$(userId));
      let after = getAfter(/databases/$(database)/documents/users/$(userId));
      return before.data.cloudRevision is int
        && after.data.cloudRevision is int
        && after.data.cloudRevision == before.data.cloudRevision + 1;
    }

    function validBucketShard(userId, shardId) {
      return request.resource.data.keys().hasAll([
          'owner',
          'shardId',
          'items',
          'count',
          'cloudRevision',
          'storageVersion',
          'updatedAt'
        ])
        && request.resource.data.owner == userId
        && request.resource.data.shardId == shardId
        && request.resource.data.items is list
        && request.resource.data.count is int
        && request.resource.data.count == request.resource.data.items.size()
        && request.resource.data.count >= 0
        && request.resource.data.count <= 250
        && request.resource.data.cloudRevision is int
        && request.resource.data.cloudRevision == getAfter(/databases/$(database)/documents/users/$(userId)).data.cloudRevision
        && request.resource.data.storageVersion == 1
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time;
    }

    function validBattleRecord(userId) {
      return request.resource.data.keys().hasAll([
          'owner',
          'type',
          'position',
          'record',
          'cloudRevision',
          'storageVersion',
          'updatedAt'
        ])
        && request.resource.data.owner == userId
        && request.resource.data.type in ['boss', 'pvp']
        && request.resource.data.position is int
        && request.resource.data.position >= 0
        && request.resource.data.position < 5
        && request.resource.data.record is map
        && request.resource.data.cloudRevision is int
        && request.resource.data.cloudRevision == getAfter(/databases/$(database)/documents/users/$(userId)).data.cloudRevision
        && request.resource.data.storageVersion == 2
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time;
    }

    function validBattleFrameChunk(userId) {
      return request.resource.data.keys().hasAll([
          'owner',
          'recordId',
          'chunkIndex',
          'chunkCount',
          'frames',
          'cloudRevision',
          'storageVersion',
          'updatedAt'
        ])
        && request.resource.data.owner == userId
        && request.resource.data.recordId is string
        && request.resource.data.recordId.size() > 0
        && request.resource.data.chunkIndex is int
        && request.resource.data.chunkIndex >= 0
        && request.resource.data.chunkCount is int
        && request.resource.data.chunkCount > 0
        && request.resource.data.chunkIndex < request.resource.data.chunkCount
        && request.resource.data.frames is list
        && request.resource.data.frames.size() > 0
        && request.resource.data.frames.size() <= 80
        && request.resource.data.cloudRevision is int
        && request.resource.data.cloudRevision == getAfter(/databases/$(database)/documents/users/$(userId)).data.cloudRevision
        && request.resource.data.storageVersion == 2
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow read: if true;

      allow create: if isAdmin() || (validWriteEnvelope(request.resource.data)
        && validUserCore(request.resource.data)
        && request.resource.data.keys().hasAll([
          'passwordHash',
          'sessionTokenHash',
          'sessionTokens',
          'activeSessionDeviceId',
          'activeSessionTokenHash',
          'activeSessionSeenAt',
          'accountResetVersion',
          'createdAt'
        ])
        && request.resource.data.passwordHash is string
        && request.resource.data.sessionTokenHash is string
        && request.resource.data.sessionTokens is map
        && request.resource.data.activeSessionDeviceId is string
        && request.resource.data.activeSessionTokenHash is string
        && request.resource.data.activeSessionSeenAt is timestamp
        && request.resource.data.activeSessionSeenAt == request.time
        && request.resource.data.nickname == userId
        && request.resource.data.cloudRevision == 0
        && request.resource.data.writeProtocolSeq == 1
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdAt == request.time);

      allow update: if isAdmin() || (validWriteEnvelope(request.resource.data)
        && validUserCore(request.resource.data)
        && writeGuardChanged()
        && identityFieldsUnchanged()
        && validUpdateSequence()
        && (progressDoesNotRegress() || validFullReset())
        && request.resource.data.nickname == userId);

      allow delete: if isAdmin() || activeSessionMatches(userId);

      match /backups/{slotId} {
        allow read: if false;

        allow create, update: if isAdmin() || (slotId in ['slot0', 'slot1', 'slot2']
          && validWriteEnvelope(request.resource.data)
          && request.resource.data.username == userId
          && request.resource.data.slot is int
          && request.resource.data.slot >= 0
          && request.resource.data.slot < 3
          && request.resource.data.sourceRevision is int
          && request.resource.data.sourceRevision >= 0
          && request.resource.data.summary is map
          && request.resource.data.gameState is map
          && request.resource.data.capturedAt is timestamp
          && request.resource.data.capturedAt == request.time);

        allow delete: if isAdmin() || parentActiveSessionMatches(userId);
      }

      match /bucketShards/{shardId} {
        allow read: if true;
        allow create, update: if isAdmin() || (parentRevisionAdvanced(userId)
          && validBucketShard(userId, shardId));
        allow delete: if isAdmin() || parentRevisionAdvanced(userId)
          || parentActiveSessionMatches(userId);
      }

      match /battleRecords/{recordId} {
        allow read: if true;
        allow create, update: if isAdmin() || (parentRevisionAdvanced(userId)
          && validBattleRecord(userId));
        allow delete: if isAdmin() || parentRevisionAdvanced(userId)
          || parentActiveSessionMatches(userId);
      }

      match /battleRecordFrames/{chunkId} {
        allow read: if true;
        allow create, update: if isAdmin() || (parentRevisionAdvanced(userId)
          && validBattleFrameChunk(userId));
        allow delete: if isAdmin() || parentRevisionAdvanced(userId)
          || parentActiveSessionMatches(userId);
      }
    }

    match /config/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminAuditLogs/{documentId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /serverAlerts/{documentId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    match /onlineUsers/{documentId} {
      allow read, write: if true;
    }

    match /accountSessions/{documentId} {
      allow read, create, update, delete: if true;
    }

    match /pvpRequests/{documentId} {
      allow read, write: if true;
    }

    match /pvpRooms/{documentId} {
      allow read, write: if true;
    }

    match /pvpActive/{documentId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
